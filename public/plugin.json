{
  "main": "index.html",
  "preload": "preload/services.js",
  "logo": "logo.png",
  "development": {
    "main": "http://localhost:5173"
  },
  "features": [
    {
      "code": "nvm",
      "explain": "基于NVM和uTools的可视化node版本管理应用。",
      "cmds": [
        "nvm",
        "nvm-ui"
      ]
    },
    {
      "code": "nvm use",
      "explain": "切换node版本。",
      "cmds": [
        {
          "type": "regex",
          "label": "切换",
          "match": "/^切换\\s*(.+)?/"
        }
      ]
    }
  ]
}
